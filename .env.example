# Gymnasium hosting config. Copy to `.env` and edit.
#
# Leaving TUNNEL_NAME / APP_HOST unset (or commented out) runs LOCAL-ONLY:
# start.sh boots just the app on http://localhost:$PORT with no tunnel.
# Setting BOTH engages the Cloudflare named tunnel and publishes the app
# at APP_HOST. See docs/CLOUDFLARE_TUNNEL.md for the one-time setup.

# --- Tunnel (set BOTH to publish publicly) ---
TUNNEL_NAME=gymnasium
DOMAIN=marashi.ai
APP_HOST=gymnasium.marashi.ai

# --- App ---
PORT=8000
DB=data/gymnasium.db
REPORTS=reports
DOCS=data/documents

# opencode binary the app drives for AI (default: opencode on PATH).
# OPENCODE_BIN=opencode

# Skip the `cloudflared tunnel route dns` step (after the first run, or
# when DNS is managed by hand).
# SKIP_DNS=1
